JAVA_ARGS="-XX:+AlwaysPreTouch -XX:-DisableExplicitGC -XX:+UseNUMA -XX:+UseTransparentHugePages"
JAVA_ARGS="$JAVA_ARGS -XX:+UseShenandoahGC -XX:+ClassUnloadingWithConcurrentMark -Dsun.net.client.defaultConnectTimeout=1000"
JAVA_ARGS="$JAVA_ARGS -Dfml.ignoreInvalidMinecraftCertificates=true -Dfml.ignorePatchDiscrepancies=true"
JAVA_ARGS="$JAVA_ARGS -Dfml.readTimeout=180"
JAVA_ARGS="$JAVA_ARGS -Xms6144m -Xmx6144m"
export JAVA_ARGS
